{
  "name": "rustdesk-web-portal",
  "private": true,
  "version": "1.4.9",
  "type": "module",
  "scripts": {
    "dev": "npm run generate && npm run runtime && vite --configLoader runner --host 127.0.0.1",
    "generate": "node scripts/generate-proto.mjs",
    "runtime": "node scripts/prepare-runtime.mjs",
    "check": "npm run generate && tsc --noEmit",
    "build": "npm run generate && npm run runtime && tsc --noEmit && vite build --configLoader runner",
    "preview": "vite preview --configLoader runner --host 127.0.0.1"
  },
  "dependencies": {
    "fast-sha256": "1.3.0",
    "libsodium-wrappers": "0.7.15",
    "pcm-player": "0.0.18",
    "wasm-feature-detect": "1.8.0",
    "zstddec": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "protoc": "35.1.0",
    "ts-proto": "1.181.2",
    "typescript": "5.7.3",
    "vite": "6.4.3"
  }
}
